use crate::ast::{Expr, Stmt, BinaryOperator, UnaryOperator};
use crate::typ::Type;
use crate::value::Val;
use std::str::FromStr;

grammar;

match {
    r"\s*" => { }, // ignore whitespace
    r"//[^\n\r]*" => { }, // single-line comment
    r"/\*([^*]|(\*+[^*/]))*\*+/" => { }, // multi-line comment
} else { _ }

pub Program: Vec<Box<Stmt>> = {
    <stmts:Stmt*> => stmts,
}

Stmt: Box<Stmt> = {
    <loc:@L> "break" ";" => Box::new(Stmt::Break(loc)),
    <loc:@L> "continue" ";" => Box::new(Stmt::Continue(loc)),
    <loc:@L> "return" <e:Expr> ";" => Box::new(Stmt::Return(loc, e)),
    <loc:@L> <e:Expr> ";" => Box::new(Stmt::Expr(loc, e)),

    "if" <loc:@L> <cond:Expr> <true_arm:Block> "else" <false_arm:Stmt> => Box::new(Stmt::If {loc, cond, true_arm, false_arm}),
    "if" <loc:@L> <cond:Expr> <true_arm:Block> => Box::new(Stmt::If {
        loc,
        cond,
        true_arm, 
        false_arm: Box::new(Stmt::Block(loc, vec![]))
    }),

    "while" <loc:@L> <cond:Expr> <body:Block> => Box::new(Stmt::While {loc, cond, body}),

    <loc:@L> <lhs:Expr> "=" <rhs:Expr> ";" => {
        match *lhs {
            Expr::Var(_, id) => Box::new(Stmt::Assign(loc, id, rhs)),
            Expr::Deref(_, ptr) => Box::new(Stmt::PtrUpdate(loc, ptr, rhs)),
            Expr::Subscr(_, arr, idx) => Box::new(Stmt::ArrUpdate(loc, arr, idx, rhs)),
            _ => panic!("Invalid left-hand side in assignment"),
        }
    },

    <loc:@L> <t:Type> <id:Name> "=" <e:Expr> ";" => Box::new(Stmt::Define(loc, t, id, e)),
    <loc:@L> <t:Type> <id:Name> ";" => Box::new(Stmt::Declare(loc, t, id)),
    <loc:@L> <t:Type> <id:Name> <dims:("[" <Num> "]")+> ";" => {
        let mut arr_type = t;
        for dim in dims.into_iter().rev() { arr_type = Type::Arr(Box::new(arr_type), dim as usize); }
        Box::new(Stmt::Declare(loc, arr_type, id))
    },
    <b:Block> => b,
    <loc:@L> <ret_type:Type> <name:Name> "(" <args:Comma<Param>> ")" <body:Stmt> => {
        Box::new(Stmt::FnDecl {loc, name, args, ret_type, body })
    },
}

Param: (String, Type) = {
    <t:Type> <id:Name> => (id, t),
};

Block: Box<Stmt> = {
    "{"<loc:@L> <stmts:Stmt*> "}" => Box::new(Stmt::Block(loc, stmts)),
};

Expr: Box<Expr> = {
    <loc:@L> <l:Expr> "||" <r:LogicalAnd> => Box::new(Expr::BinOp(loc, l, BinaryOperator::Or, r)),
    LogicalAnd,
}

LogicalAnd: Box<Expr> = {
    <loc:@L> <l:LogicalAnd> "&&" <r:Equality> => Box::new(Expr::BinOp(loc, l, BinaryOperator::And, r)),
    Equality,
}

Equality: Box<Expr> = {
    <loc:@L> <l:Equality> "==" <r:Comparison> => Box::new(Expr::BinOp(loc, l, BinaryOperator::Eq, r)),
    <loc:@L> <l:Equality> "!=" <r:Comparison> => Box::new(Expr::BinOp(loc, l, BinaryOperator::Neq, r)),
    Comparison,
}

Comparison: Box<Expr> = {
    <loc:@L> <l:Comparison> "<" <r:Term> => Box::new(Expr::BinOp(loc, l, BinaryOperator::Lt, r)),
    <loc:@L> <l:Comparison> "<=" <r:Term> => Box::new(Expr::BinOp(loc, l, BinaryOperator::Leq, r)),
    <loc:@L> <l:Comparison> ">" <r:Term> => Box::new(Expr::BinOp(loc, l, BinaryOperator::Gt, r)),
    <loc:@L> <l:Comparison> ">=" <r:Term> => Box::new(Expr::BinOp(loc, l, BinaryOperator::Geq, r)),
    Term,
}

Term: Box<Expr> = {
    <loc:@L> <l:Term> "+" <r:Factor> => Box::new(Expr::BinOp(loc, l, BinaryOperator::Add, r)),
    <loc:@L> <l:Term> "-" <r:Factor> => Box::new(Expr::BinOp(loc, l, BinaryOperator::Sub, r)),
    Factor,
}

Factor: Box<Expr> = {
    <loc:@L> <l:Factor> "*" <r:Prefix> => Box::new(Expr::BinOp(loc, l, BinaryOperator::Mul, r)),
    <loc:@L> <l:Factor> "/" <r:Prefix> => Box::new(Expr::BinOp(loc, l, BinaryOperator::Div, r)),
    Prefix,
}

Prefix: Box<Expr> = {
    <loc:@L> "+" <r:Prefix> => Box::new(Expr::UnOp(loc, UnaryOperator::Pos, r)),
    <loc:@L> "-" <r:Prefix> => Box::new(Expr::UnOp(loc, UnaryOperator::Neg, r)),
    <loc:@L> "!" <r:Prefix> => Box::new(Expr::UnOp(loc, UnaryOperator::Not, r)),
    <loc:@L> "&" <r:Prefix> => Box::new(Expr::AddrOf(loc, r)),
    <loc:@L> "*" <r:Prefix> => Box::new(Expr::Deref(loc, r)),
    PostFix,
}

PostFix: Box<Expr> = {
    <loc:@L> <l:PostFix> "[" <e:Expr> "]" => Box::new(Expr::Subscr(loc, l, e)),
    <loc:@L> <l:PostFix> "as" <t:Type> => Box::new(Expr::Cast(loc, l, t)),
    Atom,
}

Atom: Box<Expr> = {
    <loc:@L> "true" => Box::new(Expr::Const(loc, Val::Bool(true))),
    <loc:@L> "false" => Box::new(Expr::Const(loc, Val::Bool(false))),
    <loc:@L> <id:Name> => Box::new(Expr::Var(loc, id)),
    <loc:@L> <n:Num> => Box::new(Expr::Const(loc, Val::Int(n))),
    <loc:@L> <c:Char> => Box::new(Expr::Const(loc, Val::Byte(c))),
    <loc:@L> <name:Name> "(" <args:Comma<Expr>> ")" => Box::new(Expr::Call { loc, name, args, ret_type:None }),
    "(" <e:Expr> ")" => e,
}

Num: i32 = {
    r"[0-9]+" => i32::from_str(<>).unwrap(),
}

Char: u8 = {
    <s:r#"'([^\\']|\\[nrt0\\'"]|\\x[0-9a-fA-F]{2})'"#> => {
        let inner = &s[1..s.len()-1];
        if inner.len() == 1 { inner.as_bytes()[0] }
        else if inner.starts_with("\\x") {u8::from_str_radix(&inner[2..], 16).unwrap() }
        else {
            match inner {
                "\\n" => b'\n',
                "\\t" => b'\t',
                "\\r" => b'\r',
                "\\0" => b'\0',
                "\\'" => b'\'',
                "\\\"" => b'\"',
                _ => unreachable!("Lexer allowed an unknown escape sequence"),
            }
        }
    },
}

Name: String = {
    r"[A-Za-z_][A-Za-z_0-9]*" => String::from(<>),
}

Type: Type = {
    "ptr" "<" <t:Type> ">" => Type::Ptr(Box::new(t)),
    "int" => Type::Int,
    "bool" => Type::Bool,
    "byte" => Type::Byte,
}

Comma<T>: Vec<T> = {
    => vec![],
    
    <e:T> <v:("," <T>)*> ","? => {
        let mut res = vec![e];
        res.extend(v);
        res
    }
};

